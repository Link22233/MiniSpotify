PORT=3000
JWT_SECRET=change-me-to-long-random-string
JWT_EXPIRES=7d

# Google OAuth2 — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback

# Spotify — https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_CALLBACK_URL=http://localhost:3000/api/v1/auth/spotify/callback

# Public URL of this API (used in OAuth redirects / mobile deep links)
PUBLIC_BASE_URL=http://localhost:3000
